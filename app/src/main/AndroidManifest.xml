<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 三星 BAL 绕过：WakeDataLayerService 收到手表信号后，
         在 startActivity 前先挂一个 1×1 不可见 overlay，
         让进程进入"有可见窗口"状态，BAL checker 放行。 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 电池优化豁免：防止三星/国产 ROM 杀掉进程导致 GMS 无法投递 Data Layer 消息 -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- 手表唤醒打点时记录手机当前位置；需要"始终允许"（背景定位）
         才能在息屏/后台状态下拿到坐标 -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Android 13+ 通知权限：前台服务 / 数据同步通知需要用户显式授权 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 用户主动设置的任务闹铃；Android 12+ 无授权时会降级为非精确提醒。 -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TPlanner"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="user"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 透明代理 Activity：手表唤醒信号的中转站。
             Theme.Translucent 无 UI、excludeFromRecents 不留痕迹、
             独立 taskAffinity 不污染主任务栈。
             在 onCreate 中用 REORDER_TO_FRONT 把 MainActivity 拉回前台
             （保留用户正在编辑的内容），然后立即 finish。 -->
        <activity
            android:name=".WakeProxyActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:taskAffinity=":proxy"
            android:launchMode="singleInstance"
            android:exported="false" />

        <!-- Wearable Data Layer 监听：GMS 系统进程转发的 watch→phone 唤醒信号。
             GMS（系统进程）→ 此 Service → WakeProxyActivity → MainActivity，
             走 Google Play Services 的信道，无需自己维持前台服务。
             exported=true + intent-filter 是 GMS 发现并唤醒此服务的必要条件。 -->
        <service
            android:name=".WakeDataLayerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data android:scheme="wear" android:host="*" android:pathPrefix="/tplanner" />
            </intent-filter>
        </service>

        <receiver
            android:name=".TaskAlarmReceiver"
            android:exported="false" />

        <receiver
            android:name=".AlarmRestoreReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.app.action.SCHEDULE_EXACT_ALARM_PERMISSION_STATE_CHANGED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
