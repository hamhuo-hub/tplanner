    <path android:fillColor="#0D0D0D"
        android:pathData="M0,233 a233,233 0 1,0 466,0 a233,233 0 1,0 -466,0 z" />
    <!-- 暗金外轨（细环） -->
    <path android:strokeColor="#28C9A84C" android:strokeWidth="1.2" android:fillColor="#00000000"
        android:pathData="M137,210 a96,96 0 1,0 192,0 a96,96 0 1,0 -192,0 z" />
