    <path android:fillColor="#4A9DA8"
        android:pathData="M297,258 l3,-5 l3,5 l-3,5 z" />
    <path android:fillColor="#4A9DA8"
        android:pathData="M190,162 l3,-5 l3,5 l-3,5 z" />
